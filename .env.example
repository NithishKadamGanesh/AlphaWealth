# ===================================================================
# AlphaWealth Command Center - Environment Variables
# Copy this file to .env and fill in your secrets.
# ===================================================================
#
# QUICK START: Most things work with NO setup. The defaults below give
# you free yfinance market data, free local FinBERT sentiment (GPU),
# free local Llama 3.1 chat via Ollama (GPU), and free local FinGPT
# forecasting (GPU). Add API keys below to upgrade specific features.
#
# Tested on RTX 2080 SUPER 8GB. See ARCHITECTURE.md for GPU details.
# ===================================================================

# --- Infrastructure (defaults are fine) ---------------------------
KAFKA_BOOTSTRAP_SERVERS=redpanda:9092
DB_URL=jdbc:postgresql://postgres:5432/alphawealth
DB_USER=alphatrade
DB_PASS=alphatrade123

# --- API Authentication (optional but recommended) ---------------
# When API_TOKEN is set, every backend service (Java + Python) requires it
# on each request via 'Authorization: Bearer <token>' (health/metrics probes
# are exempt). Leave BLANK for open access in local dev. When you set it,
# also paste the same value into the UI: Settings -> Profile -> API Token.
# Generate one with:  openssl rand -hex 32
API_TOKEN=
# Restrict browser CORS to a specific UI origin (default "*" allows any).
# Example: http://localhost:3000
CORS_ALLOW_ORIGIN=*

# --- LLM Provider Selection ---------------------------------------
# Which model powers the AI Advisor chat. Options:
#   ollama  - Local Llama 3.1 8B Q5_K_M (FREE, private, GPU-accelerated)
#   claude  - Anthropic Claude Sonnet 4 (paid, best quality)
#   openai  - OpenAI GPT-4o-mini (paid, cheap)
#   gemini  - Google Gemini 2.0 Flash (free tier, 15 RPM)
#   auto    - Pick first configured key, fallback to ollama (default)
LLM_PROVIDER=auto

# --- Anthropic Claude (optional, paid) ----------------------------
# Get a key from https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- OpenAI (optional, paid) --------------------------------------
# Get a key from https://platform.openai.com
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Google Gemini (optional, free tier) --------------------------
# Get a key from https://aistudio.google.com/apikey
# Free tier: 15 requests per minute
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-exp

# --- Ollama (FREE, runs locally on GPU - DEFAULT) -----------------
# After first start, pull the model (one-time, ~5.7GB):
#   docker exec alphawealth-ollama ollama pull llama3.1:8b-instruct-q5_K_M
# Q5_K_M chosen for RTX 2080 SUPER 8GB - best quality/VRAM tradeoff.
# Other free options that fit in 8GB:
#   mistral:7b-instruct-q4_K_M    (4.4GB, faster)
#   qwen2.5:7b-instruct-q5_K_M    (5.4GB, strong reasoning)
#   llama3.1:8b-instruct-q4_K_M   (4.9GB, smaller)
OLLAMA_MODEL=llama3.1:8b-instruct-q5_K_M

# --- HuggingFace Token (optional) ---------------------------------
# Only needed if you want the official meta-llama/Llama-2 base
# instead of the open NousResearch mirror. FinGPT works without it.
# Free token: https://huggingface.co/settings/tokens
HF_TOKEN=

# --- IBKR (Interactive Brokers - optional) ------------------------
# AlphaWealth uses the IBKR Client Portal gateway in read-only mode.
# Start the local gateway, log in from Settings -> Broker Connections,
# and let ibkr-sync-svc poll it through the host gateway address.
IBKR_CP_GATEWAY_URL=https://host.docker.internal:5001
IBKR_PUBLIC_LOGIN_URL=https://localhost:5001

# --- Teller.io Banking (optional) ---------------------------------
# Real bank connections via Teller (https://teller.io). The banking service
# (teller-banking-svc) talks to https://api.teller.io.
#
# 1. Create an app at https://dashboard.teller.io and copy its Application ID.
TELLER_APP_ID=
# 2. Environment: sandbox | development | production
#    - sandbox: test institutions, NO certificate required (login user_good)
#    - development / production: REAL banks, REQUIRE an mTLS client certificate
TELLER_ENV=production
# 3. For development/production, download your Teller client certificate +
#    private key and place them here (mounted read-only into the container at
#    /certs). Paths below are the in-container locations.
TELLER_CERT_PATH=/certs/certificate.pem
TELLER_KEY_PATH=/certs/private_key.pem
#    On the host, drop the files in:   ./secrets/teller/certificate.pem
#                                      ./secrets/teller/private_key.pem

# --- Resend Email Alerts (optional, 3000/mo free) -----------------
RESEND_API_KEY=
ALERT_FROM_EMAIL=alerts@alphawealth.app
ALERT_TO_EMAIL=

# --- Grafana ------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# --- Legacy ------------------------------------------------------
ALPHA_VANTAGE_KEY=replace-me
MARKET_DATA_URL=http://localhost:8087
MODEL_INFERENCE_URL=http://localhost:8090
